# grok-search MCP 环境变量示例
# 复制为 .env 填入你自己的值（.env 已被 .gitignore 忽略，不会上传）；
# 或直接在 Claude Code 的 MCP 注册 env 里设置这些变量（见 README 的「安装」）。

# ====== 必填 ======
# OpenAI 兼容的 Grok 端点（需含 /v1），官方或任意兼容镜像/中转站均可
GROK_API_URL=https://your-grok-endpoint.example.com/v1
GROK_API_KEY=your-grok-api-key

# ====== 可选：默认模型 ======
# 也可被 ~/.config/grok-search/config.json 覆盖
# GROK_MODEL=grok-4.3-console

# ====== 可选：Tavily（web_fetch 主抓取 / web_map / extra_sources 补信源）======
# 逗号分隔可填多个 key，launcher 会自动并入轮询池；也可用单数 TAVILY_API_KEY
# TAVILY_API_KEYS=tvly-key-1,tvly-key-2
# TAVILY_API_URL=https://api.tavily.com

# ====== 可选：Firecrawl（web_fetch 降级抓取 / extra_sources / web_screenshot 三用，单 key 池）======
# 逗号分隔可填多个 key；兼容回落 FIRECRAWL_SCREENSHOT_API_KEYS
# FIRECRAWL_API_KEYS=fc-key-1,fc-key-2
# FIRECRAWL_API_URL=https://api.firecrawl.dev/v2

# ====== 可选：调试 / 日志 / 重试 ======
# GROK_DEBUG=false
# GROK_LOG_LEVEL=INFO
# GROK_LOG_DIR=logs
# GROK_RETRY_MAX_ATTEMPTS=3
# GROK_RETRY_MULTIPLIER=1
# GROK_RETRY_MAX_WAIT=10
